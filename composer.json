{
    "name": "smwks/laravel-zenith",
    "description": "Dashboard and code-driven configuration for Laravel queues running in the database.",
    "keywords": [
        "smwks",
        "laravel",
        "laravel-zenith"
    ],
    "homepage": "https://github.com/smwks/laravel-zenith",
    "license": "MIT",
    "authors": [
        {
            "name": "Ralph Schindler",
            "email": "ralph@ralphschindler.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4",
        "ext-pcntl": "*",
        "illuminate/contracts": "^11.0||^12.0",
        "livewire/livewire": "^4.0",
        "smwks/superprocess": "^0.1.1"
    },
    "require-dev": {
        "laravel/boost": "^2.1",
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^8.8",
        "orchestra/testbench": "^10.9",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "SMWks\\LaravelZenith\\": "src/",
            "SMWks\\LaravelZenith\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SMWks\\LaravelZenith\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "SMWks\\LaravelZenith\\ZenithServiceProvider"
            ],
            "aliases": {
                "LaravelZenith": "Zenith"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
